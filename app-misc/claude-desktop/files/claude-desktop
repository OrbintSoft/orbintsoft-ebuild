#!/bin/bash
# Launcher script for Claude Desktop on Gentoo

APPDIR="/opt/claude-desktop"
EXECUTABLE="${APPDIR}/claude-desktop"

if [[ ! -x "${EXECUTABLE}" ]]; then
	echo "Error: Claude Desktop executable not found at ${EXECUTABLE}" >&2
	exit 1
fi

# Impostare variabili d'ambiente per supporto Wayland
if [[ "${XDG_SESSION_TYPE}" == "wayland" ]]; then
	export ELECTRON_OZONE_PLATFORM_HINT=wayland
fi

# Lanciare l'applicazione
exec "${EXECUTABLE}" "$@"
